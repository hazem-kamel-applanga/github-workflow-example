{
  "app": {
    "base_language": "ko",
    "push": {
      "source": [
        {
          "path": "./react_json_sample/en/translations.json",
          "file_format": "i18next_json",
          "tag": "app:translations.json",
          "language": "ko"
        }
      ]
    },
    "pull": {
      "target": [
        {
          "path": "./react_json_sample/en/<language>.json",
          "file_format": "i18next_json",
          "tag": "app:translations.json",
          "exclude_languages": [
            "ko"
          ]
        }
      ]
    }
  }
}